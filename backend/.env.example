NODE_ENV=development
PORT=5000

DATABASE_URL="postgresql://username:password@localhost:5432/database_name?schema=public&options=-c%20timezone%3DUTC"

JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=1d

JWT_EMAIL_VERIFY_SECRET=your_jwt_email_verify_secret_key
JWT_EMAIL_VERIFY_EXPIRES_IN=1d

JWT_PASSWORD_RESET_SECRET=your_jwt_password_reset_secret_key
JWT_PASSWORD_RESET_EXPIRES_IN=15m

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

CORS_ORIGIN=http://localhost:3000

COOKIE_SECRET=your_cookie_secret_key